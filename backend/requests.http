@baseUrl = http://localhost:3300

### ═══════════════════════════════════════════
### BOOKS
### ═══════════════════════════════════════════

### Get all books
GET {{baseUrl}}/api/books

###

### Get books filtered by genre
GET {{baseUrl}}/api/books?genre=Fantasy

###

### Get books filtered by author
GET {{baseUrl}}/api/books?author=Tolkien

###

### Get a single book
GET {{baseUrl}}/api/books/1

###

### Create a book
POST {{baseUrl}}/api/books
Content-Type: application/json

{
  "title": "The Hobbit",
  "isbn": "9780261102217",
  "genre_id": 1
}

###

### Update a book
PUT {{baseUrl}}/api/books/1
Content-Type: application/json

{
  "title": "The Hobbit (Revised Edition)"
}

###

### Delete a book
DELETE {{baseUrl}}/api/books/1


### ═══════════════════════════════════════════
### BOOK COPIES
### ═══════════════════════════════════════════

### Get all book copies
GET {{baseUrl}}/api/book-copies

###

### Get a single book copy
GET {{baseUrl}}/api/book-copies/1

###

### Create a book copy
POST {{baseUrl}}/api/book-copies
Content-Type: application/json

{
  "book_id": 1,
  "max_rental_days": 30,
  "rent_per_day": 0.15,
  "book_condition_id": 1,
  "condition_description": "Minor wear on cover"
}

###

### Delete a book copy
DELETE {{baseUrl}}/api/book-copies/1


